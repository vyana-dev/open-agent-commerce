{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vyana.ai/schemas/asp-0.1/receipt.schema.json",
  "title": "Receipt",
  "description": "Broker-signed proof of what was purchased, delivered, and billed. Money is integer paise.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id", "kind", "version", "issued_at", "idp", "user_id", "service",
    "transaction_id", "line_items", "subtotal_paise", "tax_paise", "total_paise",
    "currency", "delivery", "billed_to", "signature_alg", "signature"
  ],
  "properties": {
    "receipt_id": { "type": "string" },
    "kind": { "type": "string", "enum": ["signup", "payment", "subscription", "refund"] },
    "version": { "const": "asp-0.1" },
    "issued_at": { "type": "string", "format": "date-time" },
    "idp": { "type": "string" },
    "user_id": { "type": "string" },
    "service": { "type": "string" },
    "account_ref": { "type": "string" },
    "transaction_id": { "type": "string" },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "amount_paise"],
        "properties": {
          "description": { "type": "string" },
          "amount_paise": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "subtotal_paise": { "type": "integer", "minimum": 0 },
    "tax_paise": { "type": "integer", "minimum": 0 },
    "total_paise": { "type": "integer", "minimum": 0 },
    "currency": { "const": "INR" },
    "delivery": { "type": "string", "enum": ["pending", "delivered", "failed"] },
    "billed_to": { "type": "string", "enum": ["user", "broker"] },
    "signature_alg": { "const": "EdDSA" },
    "signature": { "type": "string", "description": "broker-signed, base64" }
  }
}
