{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vyana.ai/schemas/asp-0.1/credential-capsule.schema.json",
  "title": "CredentialCapsule",
  "description": "Broker-signed signup result returned to the agent (ASP §8).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capsule_id", "mandate_id", "issued_at", "service", "strategy_used",
    "tos_class_used", "credentials", "provenance", "signature_alg", "signature"
  ],
  "properties": {
    "capsule_id": { "type": "string" },
    "mandate_id": { "type": "string" },
    "issued_at": { "type": "string", "format": "date-time" },
    "service": { "type": "string" },
    "strategy_used": {
      "type": "string",
      "enum": ["native-asp", "oauth-app", "cli-session-reuse", "paste-token", "browser-automation"]
    },
    "tos_class_used": { "type": "string", "enum": ["A", "B", "C"] },
    "provisioned_resource_id": { "type": "string" },
    "account_creation_receipt": { "type": "string", "description": "JWS, native-asp only" },
    "account_ownership_certificate": { "type": "string", "description": "JWS, native-asp only" },
    "credentials": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "value", "expires_at"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["api_key", "oauth_token", "password", "ssh_key", "identifier"] },
          "value": { "type": "string", "description": "encrypted unless type === identifier" },
          "expires_at": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chain_id", "head_hash", "events_count"],
      "properties": {
        "chain_id": { "type": "string" },
        "head_hash": { "type": "string" },
        "events_count": { "type": "integer", "minimum": 0 }
      }
    },
    "signature_alg": { "const": "EdDSA" },
    "signature": { "type": "string" }
  }
}
