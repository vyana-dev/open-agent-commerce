{
  "name": "@vyana/open-agent-commerce",
  "version": "0.1.0",
  "description": "Open Agent Commerce reference primitives: wire objects, canonical JSON, Ed25519 signing/verification, credential-capsule encryption, and the Unified Agent Protocol adapters (TAP/AP2/ACP/Vyana).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "example": "node --experimental-strip-types ../../examples/sign-and-verify.ts"
  },
  "keywords": [
    "agent",
    "agentic-commerce",
    "ai-agents",
    "ed25519",
    "signup",
    "payments",
    "mandate",
    "protocol"
  ],
  "engines": { "node": ">=20" },
  "repository": {
    "type": "git",
    "url": "https://github.com/vyana-dev/open-agent-commerce.git",
    "directory": "packages/open-agent-commerce"
  },
  "homepage": "https://github.com/vyana-dev/open-agent-commerce#readme",
  "publishConfig": { "access": "public" }
}
