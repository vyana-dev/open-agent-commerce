{
  "name": "open-agent-commerce",
  "version": "0.1.0",
  "private": true,
  "description": "Open Agent Commerce — open protocols + reference primitives for AI-agent signup, payment (AP2-aligned), and a unified cross-rail authorization layer.",
  "type": "module",
  "license": "MIT",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspace @vyana/open-agent-commerce",
    "typecheck": "npm run typecheck --workspace @vyana/open-agent-commerce",
    "examples": "node --experimental-strip-types examples/sign-and-verify.ts && node --experimental-strip-types examples/unify-protocols.ts",
    "conformance": "node conformance/run.mjs",
    "test": "npm run typecheck && npm run build && npm run examples && npm run conformance"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vyana-dev/open-agent-commerce.git"
  },
  "engines": { "node": ">=22" }
}
